# Copy this file to .env and set your real keys locally. Never commit .env.
# Keep only placeholder values here (safe for public GitHub).
# Get a key: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: Nebius (Lesson 7 and others). Get key: https://console.nebius.ai
# NEBIUS_API_KEY=your_nebius_api_key_here

# Langfuse (Lesson 7 - Observability). Get keys: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com
